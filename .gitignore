```gitignore
# Virtual environments
.venv/
.env.local

# Python cache
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs
*.log
logs/

# Environment variables
.env
.env.*
!.env.example

# IDEs
.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/
.pyre/
.pytype/

# Ruff
.ruff_cache/

# OS files
.DS_Store
Thumbs.db

# SQLite
*.sqlite3
*.db

# Temporary files
*.tmp
*.temp

# Model checkpoints
*.ckpt
*.pth
*.pt
*.onnx
*.h5
*.keras
*.joblib
*.pkl

# Data
data/
datasets/
uploads/
outputs/
results/

# Misc
.cache/
```
