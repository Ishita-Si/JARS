# Copy this file to .env.local and fill in real values.

# Used to sign JWTs for auth. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# SQLite by default; swap for Postgres in production, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/jars
DATABASE_URL=sqlite:///./jars.db

# Required for the /api/insights endpoint (AI runtime explanations).
GEMINI_API_KEY=
